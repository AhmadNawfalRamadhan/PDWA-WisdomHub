# ==============================================
# WisdomHub - Environment Configuration Template
# ==============================================
# Salin file ini menjadi .env dan sesuaikan nilainya.
# cp .env.example .env

# Application
APP_NAME=WisdomHub
APP_URL=http://localhost/WisdomHub
APP_ENV=local
APP_DEBUG=true

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=your_db_password
DB_NAME=wisdomhub
DB_CHARSET=utf8mb4

# Library Settings
FINE_PER_DAY=1000
BORROW_DAYS=14

# Mail (SMTP) - Opsional, untuk Forgot Password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=youremail@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=youremail@gmail.com
MAIL_FROM_NAME=WisdomHub